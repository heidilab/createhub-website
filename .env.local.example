# ──────────────────────────────────────────────
# Firebase Web App config (client-side, public)
# 喺 Firebase Console > Project Settings > Your apps > Web
# ──────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──────────────────────────────────────────────
# Firebase Admin SDK（server-side, 只用於 server / API routes）
# 喺 Firebase Console > Project Settings > Service accounts > Generate new private key
# 下載 JSON 後將 3 個欄位貼過嚟：
#   - project_id     → FIREBASE_ADMIN_PROJECT_ID
#   - client_email   → FIREBASE_ADMIN_CLIENT_EMAIL
#   - private_key    → FIREBASE_ADMIN_PRIVATE_KEY（保留 "\n"，整個貼落雙引號）
# ──────────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# ──────────────────────────────────────────────
# Resend（Email）
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@createhub.biz
RESEND_FROM_NAME=創研社 CREATE HUB

# ──────────────────────────────────────────────
# Stripe（付款）
# 喺 https://dashboard.stripe.com/apikeys 攞
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.createhub.biz
NEXT_PUBLIC_LEARNWORLDS_URL=https://createhub.learnworlds.com/home

# ──────────────────────────────────────────────
# Admin
# ──────────────────────────────────────────────
ADMIN_EMAIL=info@createhub.biz
